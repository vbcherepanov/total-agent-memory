[Unit]
Description=total-agent-memory Dashboard (v12.0)
Documentation=https://github.com/vbcherepanov/total-agent-memory
After=default.target

[Service]
Type=simple
WorkingDirectory=@INSTALL_DIR@
ExecStart=@INSTALL_DIR@/.venv/bin/python @INSTALL_DIR@/src/dashboard.py
Restart=on-failure
RestartSec=5
Environment=TAM_MEMORY_DIR=@MEMORY_DIR@
Environment=DASHBOARD_PORT=37737
StandardOutput=append:@MEMORY_DIR@/logs/dashboard.log
StandardError=append:@MEMORY_DIR@/logs/dashboard.err
# Lower priority so the dashboard doesn't fight the MCP server
Nice=5

[Install]
WantedBy=default.target
