[Unit]
Description=Claude Memory — periodic orphan-edge backfill (KG consolidation)
Documentation=https://github.com/vbcherepanov/total-agent-memory
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=@INSTALL_DIR@
ExecStart=@INSTALL_DIR@/.venv/bin/python @INSTALL_DIR@/src/tools/backfill_orphan_edges.py --min-mentions=1 --limit=500 --trigger-now
Environment=TAM_MEMORY_DIR=@MEMORY_DIR@
Environment=MEMORY_LLM_MODEL=qwen2.5-coder:7b
# Lower priority so it doesn't compete with MCP server
Nice=10
TimeoutStartSec=1800
StandardOutput=append:@MEMORY_DIR@/logs/orphan-backfill.log
StandardError=append:@MEMORY_DIR@/logs/orphan-backfill.log
