[Unit]
Description=Claude Memory — drain reflection queues via Ollama (one-shot)
Documentation=https://github.com/vbcherepanov/total-agent-memory
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=@INSTALL_DIR@
ExecStart=@INSTALL_DIR@/.venv/bin/python @INSTALL_DIR@/src/tools/run_reflection.py
Environment=CLAUDE_MEMORY_DIR=@MEMORY_DIR@
# Cold Ollama load ~30s first time, then ~10s per queue item
TimeoutStartSec=1200
Nice=10
StandardOutput=journal
StandardError=journal
